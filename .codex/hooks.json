{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "codex-langfuse-enqueue",
            "statusMessage": "Queueing Langfuse Codex telemetry"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "codex-langfuse-enqueue",
            "statusMessage": "Queueing Langfuse Codex telemetry"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "codex-langfuse-enqueue",
            "statusMessage": "Queueing Langfuse Codex telemetry"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "codex-langfuse-enqueue",
            "statusMessage": "Queueing Langfuse Codex telemetry"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "codex-langfuse-enqueue",
            "statusMessage": "Queueing Langfuse Codex telemetry",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
