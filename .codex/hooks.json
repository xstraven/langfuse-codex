{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/langfuse_enqueue.py\"",
            "statusMessage": "Queueing Langfuse Codex telemetry"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/langfuse_enqueue.py\"",
            "statusMessage": "Queueing Langfuse Codex telemetry"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/langfuse_enqueue.py\"",
            "statusMessage": "Queueing Langfuse Codex telemetry"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/langfuse_enqueue.py\"",
            "statusMessage": "Queueing Langfuse Codex telemetry"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/langfuse_enqueue.py\"",
            "statusMessage": "Queueing Langfuse Codex telemetry",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
